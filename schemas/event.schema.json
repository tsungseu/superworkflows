{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.superworkflows/schemas/event.schema.json",
  "title": "Superworkflows Journal Event",
  "type": "object",
  "required": ["seq", "event_id", "timestamp", "type", "actor", "previous_hash", "payload", "hash"],
  "properties": {
    "seq": {"type": "integer", "minimum": 1},
    "event_id": {"type": "string"},
    "previous_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "payload": {
      "type": "object",
      "required": ["details", "post_state"]
    }
  },
  "additionalProperties": true
}
