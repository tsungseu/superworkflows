{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.superworkflows/schemas/run-state.schema.json",
  "title": "Superworkflows Run State",
  "type": "object",
  "required": [
    "schema_version",
    "plugin_version",
    "run_id",
    "repository_fingerprint",
    "project_policy_hash",
    "workflow_spec_hash",
    "agent_contract_hash",
    "state",
    "status",
    "route_trace",
    "findings",
    "evidence",
    "approvals",
    "external_actions",
    "last_event_seq",
    "previous_event_hash"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "run_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$"},
    "parent_run_id": {"type": ["string", "null"]},
    "project_policy_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "workflow_spec_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "agent_contract_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "state": {"type": "string"},
    "status": {"enum": ["ACTIVE", "PAUSED", "BLOCKED", "COMPLETE", "CANCELLED"]},
    "last_event_seq": {"type": "integer", "minimum": 1},
    "previous_event_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "route_trace": {"type": "array"},
    "findings": {"type": "array"},
    "evidence": {"type": "array"},
    "approvals": {"type": "array"},
    "external_actions": {"type": "array"}
  },
  "additionalProperties": true
}
